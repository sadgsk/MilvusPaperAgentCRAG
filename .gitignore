# ========================
# 1. 环境变量与机密信息 (最核心的安全防线)
# ========================
.env
.env.local
.env.*

# ========================
# 2. 本地数据与数据库存储卷
# ========================
venom_data/
uploads/
*.db

# ========================
# 3. Python 与 虚拟环境
# ========================
__pycache__/
*.py[cod]
*$py.class
.venv/
.venv1/
venv/

# ========================
# 4. IDE (PyCharm) 配置文件
# ========================
.idea/
*.swp
*.swo

# ========================
# 5. 日志与临时文件
# ========================
*.log
logs/
.temp/